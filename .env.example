# Replace these values with your own keys

# Coding agent: Claude Agent SDK against a real Anthropic model/key.
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-5

# Orchestrator + research/content agents: local Ollama model (must be pulled
# and served by `ollama serve`, default http://localhost:11434).
OLLAMA_MODEL=gpt-oss:20b

# LLM-semantic observability (prompts/completions/cost) for the LangChain-based
# agents - content_agent and research_agent. Leave blank to disable; Jaeger
# tracing below works independently of this. Get keys at cloud.langfuse.com
# (or your self-hosted instance's project settings).
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

AGENT_STORAGE_DIR=./storage
AGENT_CHECKPOINT_DB=./state/checkpoint.sqlite
ADK_DEV_UI=http://localhost:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service topology - the orchestrator calls these over A2A/HTTP.
CODE_AGENT_HOST=localhost
CODE_AGENT_PORT=8001
CODE_AGENT_URL=http://localhost:8001

RESEARCH_AGENT_HOST=localhost
RESEARCH_AGENT_PORT=8002
RESEARCH_AGENT_URL=http://localhost:8002

ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
