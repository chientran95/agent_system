# Replace these values with your own keys
LANGCHAIN_API_KEY=your_langchain_api_key

# Coding agent: Claude Agent SDK against a real Anthropic model/key.
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-5

# Orchestrator + content agent: local Ollama model (must be pulled and served
# by `ollama serve`, default http://localhost:11434).
OLLAMA_MODEL=gpt-oss:20b

AGENT_STORAGE_DIR=./storage
AGENT_CHECKPOINT_DB=./state/checkpoint.sqlite
ADK_DEV_UI=http://localhost:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service topology - the orchestrator calls these over A2A/HTTP.
CODE_AGENT_HOST=localhost
CODE_AGENT_PORT=8001
CODE_AGENT_URL=http://localhost:8001

CONTENT_AGENT_HOST=localhost
CONTENT_AGENT_PORT=8002
CONTENT_AGENT_URL=http://localhost:8002

ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
